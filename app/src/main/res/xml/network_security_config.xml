<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Config — enforces TLS everywhere.
  No cleartext traffic permitted. All outgoing requests must be HTTPS.
  Domains must also be in the AllowList (enforced by OkHttp interceptor).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Localhost for sandbox dev server only -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
